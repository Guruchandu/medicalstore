{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/",
      "destination": "/frontend/html/index.html"
    },
    {
      "source": "/(css|js|public)/(.*)",
      "destination": "/frontend/$1/$2"
    },
    {
      "source": "/(.*)\\.html",
      "destination": "/frontend/html/$1.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/html/$1.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
